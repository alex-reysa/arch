# Dependencies
node_modules/
.pnpm-store/

# Build artifacts
dist/
build/
*.tsbuildinfo

# Test artifacts
coverage/
.vitest-cache/

# Benchmark run outputs (the committed dataset lives under benchmarks/)
artifacts/bench/
